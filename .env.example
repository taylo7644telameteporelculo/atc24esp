# Copia este archivo a ".env" (mismo folder) y completa cada valor.
# Nunca compartas este archivo ni lo subas a git una vez completado.

# Developer Portal > tu app > OAuth2 > General
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Developer Portal > tu app > Bot > Reset Token
DISCORD_BOT_TOKEN=

# ID de tu servidor de Discord (clic derecho al icono del server > Copiar ID)
DISCORD_GUILD_ID=

# Debe coincidir EXACTO con el redirect que registraste en el Developer Portal
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# IDs de los roles del servidor (Ajustes del servidor > Roles > clic derecho > Copiar ID)
ROLE_ID_ADMIN=
ROLE_ID_CONTROLLER=
ROLE_ID_PILOT=

# Cualquier cadena larga y aleatoria, solo para firmar la sesión localmente
SESSION_SECRET=cambia-esto-por-algo-largo-y-aleatorio

PORT=3000
